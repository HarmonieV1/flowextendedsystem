{
  "appId": "com.fxsedge.app",
  "appName": "FXSEDGE",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#00e5a0"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#09090b"
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#09090b",
      "showSpinner": false
    },
    "Keyboard": {
      "resize": "native",
      "style": "dark"
    }
  }
}
